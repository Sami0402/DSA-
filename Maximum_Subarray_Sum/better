def maxSubArraySum(a):
    n = len(a)
    maxS = -100000
    for i in range(n):
        
        sum = 0
        for j in range(i, n):
            sum += a[j]
                
            maxS = max(maxS, sum)
            
            
    return maxS
    

a = [-2, -3, 4,-1,-2, 1,5,-3]

print(maxSubArraySum(a))
