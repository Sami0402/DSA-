def markMatrixZero(a):
    m = len(a)
    n = len(a[0])
    
    # Flag to track if first row should be zeroed
    first_row_zero = False
     # Flag to track if first column should be zeroed
    first_col_zero = False
    
    # Check if first row has any zero  (Column Marker)
    for i in range(m):
        
        if a[i][0] == 0:
            first_row_zero = True
    
    # Check if first column has any zero  ( Row Marker )   
    for j in range(n):
        if a[0][j] == 0:
            first_col_zero = True
    
    # Mark in first row/column
    for i in range(m):
        for j in range(n):
            if a[i][j] == 0:
                a[i][0] = 0
                a[0][j] = 0
    
    # Set cells to zero based on markers(first row/column)           
    for i in range(1,m):
        for j in range(1,n):
            if a[i][0] == 0 or a[0][j] == 0:
                a[i][j] = 0
    
    # Zero the first row if it has a zero
    if first_row_zero:
        for i in range(m):
            a[i][0] = 0
    
    # Zero the first col if it has a zero
    if first_col_zero:
        for j in range(n):
            a[0][j] = 0
            

matrix = [[1,1,1],[1,0,1],[1,1,1]]
markMatrixZero(matrix)

print(matrix)
                
