def subArrDivByK(a):
    k = 5
    n = len(a)
    result = 0
    
    # calculate prefSum array
    for i in range(1, n):
        a[i] += a[i-1]
    
    for i in range(n):
        sum = 0
        for j in range(i, n):
            sum = a[j] if (i == 0) else a[j] - a[i-1]
            
            if sum%k == 0:
                result += 1
                
    return result
    
    
a = [4,5,0,-2,-3,1]

print(subArrDivByK(a))
