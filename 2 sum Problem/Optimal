a = [2,6,5,8,11]
target = 14



def checkSum(a, target):
    a.sort()
    i = 0
    j = len(a) - 1
    while i < j :
        
        if a[i] + a[j] > target:
            j -= 1
        elif a[i] + a[j] < target:
            i += 1
        
        if a[i] + a[j] == target:
            return "Yes"
            
    return "No"
            
                

print(checkSum(a,14))
