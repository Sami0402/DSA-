def rotateMatrix(a):
    m = len(a)
    n = len(a[0])
    
    ans = [ [0 for _ in range(n)]  for _ in range(m)]
    
    for i in range(m):
        for j in range(n):
            ans[j][(n-1) - i] = a[i][j]
            
    
    return ans
            

matrix = [
    [1,2],
    [5,6]
    ]
    

print(rotateMatrix(matrix))
