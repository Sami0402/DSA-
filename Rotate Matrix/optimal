def rotateMatrix(a):
    m = len(a)
    n = len(a[0])
    
    # swap elements
    for i in range(m):
        for j in range( i+1, n):
            a[i][j], a[j][i] = a[j][i], a[i][j]
            
    # reverse rows
    for i in range(m):
        a[i].reverse()
            
    
    return a
            

matrix = [
    [1,2,3],[4,5,6],[7,8,9]
    ]
    

print(rotateMatrix(matrix))
